// =============================================================================
//  EEPROM — Locations
// =============================================================================
void saveLocations() {
  int addr = 0;
  EEPROM.write(addr, locationCount);
  addr++;
  for (int i = 0; i < locationCount; i++) {
    EEPROM.put(addr, locations[i]);
    addr += sizeof(Location);
  }
  EEPROM.commit();
  publishLocations();  // keep app in sync
}

void loadLocations() {
  int addr = 0;
  locationCount = EEPROM.read(addr);
  addr++;
  if (locationCount > 10) locationCount = 0;
  for (int i = 0; i < locationCount; i++) {
    EEPROM.get(addr, locations[i]);
    addr += sizeof(Location);
  }
}

// =============================================================================
//  EEPROM — WiFi config
// =============================================================================
void saveWiFiNetworks() {
  int addr = WIFI_EEPROM_ADDR;
  EEPROM.write(addr, (uint8_t)savedNetworkCount); addr++;
  for (int i = 0; i < MAX_SAVED_WIFI; i++) {
    EEPROM.put(addr, savedNetworks[i]); addr += sizeof(SavedNetwork);
  }
  EEPROM.commit();
}

void loadWiFiNetworks() {
  int addr = WIFI_EEPROM_ADDR;
  savedNetworkCount = EEPROM.read(addr); addr++;
  if (savedNetworkCount > MAX_SAVED_WIFI || savedNetworkCount < 0)
    savedNetworkCount = 0;
  for (int i = 0; i < MAX_SAVED_WIFI; i++) {
    EEPROM.get(addr, savedNetworks[i]); addr += sizeof(SavedNetwork);
    // validate
    if (savedNetworks[i].ssid[0] < 32 || savedNetworks[i].ssid[0] > 126)
      memset(&savedNetworks[i], 0, sizeof(SavedNetwork));
  }
}

// Try each saved network in order, connect to first that succeeds
void autoConnectWiFi() {
  for (int i = 0; i < savedNetworkCount; i++) {
    if (strlen(savedNetworks[i].ssid) == 0) continue;
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(0, 0);  display.print("Connecting...");
    display.setCursor(0, 12); display.print(savedNetworks[i].ssid);
    display.display();

    WiFi.disconnect(true);
    WiFi.mode(WIFI_STA);
    if (savedNetworks[i].enterprise) {
      esp_eap_client_set_identity((uint8_t*)savedNetworks[i].username, strlen(savedNetworks[i].username));
      esp_eap_client_set_username((uint8_t*)savedNetworks[i].username, strlen(savedNetworks[i].username));
      esp_eap_client_set_password((uint8_t*)savedNetworks[i].password, strlen(savedNetworks[i].password));
      esp_wifi_sta_enterprise_enable();
      WiFi.begin(savedNetworks[i].ssid);
    } else {
      WiFi.begin(savedNetworks[i].ssid, savedNetworks[i].password);
    }
    int attempts = 0;
    while (WiFi.status() != WL_CONNECTED && attempts < 14) {
      delay(400); attempts++;
    }
    if (WiFi.status() == WL_CONNECTED) {
      wifiConnected = true;
      activeNetworkIdx = i;
      display.clearDisplay();
      display.setCursor(0, 0);  display.print("Connected!");
      display.setCursor(0, 12); display.print(savedNetworks[i].ssid);
      display.setCursor(0, 24); display.print(WiFi.localIP().toString());
      display.display();
      delay(1500);
      return;
    }
  }
  wifiConnected = false;
  activeNetworkIdx = -1;
}

// Connect a specific network by index — directly, no scanning other saved networks
void connectNetworkByIndex(int idx) {
  if (idx < 0 || idx >= savedNetworkCount) return;
  WiFi.disconnect(true);
  WiFi.mode(WIFI_STA);
  delay(100);
  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(0, 0);  display.print("Connecting...");
  display.setCursor(0, 12); display.print(savedNetworks[idx].ssid);
  display.display();
  if (savedNetworks[idx].enterprise) {
    esp_eap_client_set_identity((uint8_t*)savedNetworks[idx].username, strlen(savedNetworks[idx].username));
    esp_eap_client_set_username((uint8_t*)savedNetworks[idx].username, strlen(savedNetworks[idx].username));
    esp_eap_client_set_password((uint8_t*)savedNetworks[idx].password, strlen(savedNetworks[idx].password));
    esp_wifi_sta_enterprise_enable();
    WiFi.begin(savedNetworks[idx].ssid);
  } else {
    WiFi.begin(savedNetworks[idx].ssid, savedNetworks[idx].password);
  }
  int att = 0;
  while (WiFi.status() != WL_CONNECTED && att < 20) { delay(400); att++; }
  if (WiFi.status() == WL_CONNECTED) {
    wifiConnected = true; activeNetworkIdx = idx;
    display.clearDisplay();
    display.setCursor(0, 0);  display.print("Connected!");
    display.setCursor(0, 12); display.print(savedNetworks[idx].ssid);
    display.setCursor(0, 24); display.print(WiFi.localIP().toString());
    display.display(); delay(1500);
  } else {
    wifiConnected = false;
    display.clearDisplay();
    display.setCursor(0, 0);  display.print("Failed!");
    display.setCursor(0, 12); display.print(savedNetworks[idx].ssid);
    display.setCursor(0, 24); display.print("Check credentials");
    display.display(); delay(1500);
  }
}

