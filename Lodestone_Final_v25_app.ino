// Format GPS time as HH:MM from TinyGPS
static void printGpsTime() {
  if (!gps.time.isValid()) { display.print("--:--"); return; }
  // Convert UTC to IST (UTC+5:30)
  int totalMin = gps.time.hour() * 60 + gps.time.minute() + 330;
  totalMin %= (24 * 60);
  if (totalMin < 0) totalMin += 24 * 60;
  char buf[6];
  snprintf(buf, sizeof(buf), "%02d:%02d", totalMin / 60, totalMin % 60);
  display.print(buf);
}

void runNavigation() {
  float hdg = getHeading();
  float roll, pitch;
  getTilt(roll, pitch);
  bool tiltWarn = (fabsf(roll) > TILT_WARN_DEG || fabsf(pitch) > TILT_WARN_DEG);

  while (GPS_SERIAL.available()) gps.encode(GPS_SERIAL.read());

  if (!gps.location.isValid()) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(22, 0);  display.print("Acquiring GPS");
    display.setCursor(10, 14); display.print("Please wait...");
    // Animated dots
    static uint8_t dots = 0;
    static unsigned long lastDot = 0;
    if (millis() - lastDot > 500) { dots = (dots + 1) % 4; lastDot = millis(); }
    display.setCursor(10, 28);
    for (uint8_t i = 0; i < dots; i++) display.print(".");
    if (tiltWarn) { display.setCursor(20, 54); display.print("!! TILT !!"); }
    display.display();
    if (btnPressed(BTN_LEFT)) { state = MAIN_MENU; menuIndex = 0; }
    return;
  }

  float rawBrg  = (float)TinyGPSPlus::courseTo(
                    gps.location.lat(), gps.location.lng(), TARGET_LAT, TARGET_LON);
  float rawDist = (float)TinyGPSPlus::distanceBetween(
                    gps.location.lat(), gps.location.lng(), TARGET_LAT, TARGET_LON);

  if (smoothBearing < 0.0f) { smoothBearing = rawBrg; smoothDist = rawDist; }

  smoothBearing = circularEMA(smoothBearing, rawBrg, 0.25f);
  smoothDist    = 0.75f * smoothDist + 0.25f * rawDist;

  float rawRel = smoothBearing - hdg;
  if (rawRel >  180.0f) rawRel -= 360.0f;
  if (rawRel < -180.0f) rawRel += 360.0f;

  float relFor360 = rawRel + 180.0f;
  float sfFor360  = smoothRelAngle + 180.0f;
  sfFor360 = circularEMA(sfFor360, relFor360, 0.25f);
  smoothRelAngle = sfFor360 - 180.0f;

  int frame = relToFrame(smoothRelAngle);
  int relDeg = (int)smoothRelAngle;

  display.clearDisplay();
  display.setTextSize(1);

  // ── Row 0 (y=0): target name centered — OR tilt warning ───────────────────
  if (tiltWarn) {
    display.setCursor(0, 0); display.print("!! TILT !!");
  } else {
    int nameLen = strlen(TARGET_NAME);
    int nameX = (128 - nameLen * 6) / 2;
    if (nameX < 0) nameX = 0;
    display.setCursor(nameX, 0);
    display.print(TARGET_NAME);
  }

  // ── Arrow centered horizontally, y=8..55 (48px, no overlap) ──────────────
  // x = (128 - 48) / 2 = 40
  display.drawBitmap(40, 8, frames[frame], FRAME_WIDTH, FRAME_HEIGHT, WHITE);

  // ── Bottom row (y=56): angle LEFT | distance RIGHT ─────────────────────────
  // Angle
  display.setCursor(0, 56);
  if (relDeg == 0) {
    display.print("ON TARGET");
  } else {
    if (relDeg > 0) display.print("+");
    display.print(relDeg);
    display.print((char)247);
    if      (abs(relDeg) <= 45)  display.print(relDeg > 0 ? " slR" : " slL");
    else if (abs(relDeg) <= 135) display.print(relDeg > 0 ? " R"   : " L");
    else                         display.print(relDeg > 0 ? " bkR" : " bkL");
  }
  // Distance right-aligned
  char distBuf[10];
  if (smoothDist >= 1000.0f)
    snprintf(distBuf, sizeof(distBuf), "%.1fkm", smoothDist / 1000.0f);
  else
    snprintf(distBuf, sizeof(distBuf), "%dm", (int)smoothDist);
  int distX = 127 - (int)strlen(distBuf) * 6;
  display.setCursor(distX, 56);
  display.print(distBuf);

  display.display();
  if (btnPressed(BTN_LEFT)) {
    smoothBearing = -1.0f;
    state = MAIN_MENU; menuIndex = 0;
  }
}

