// =============================================================================
//  DEVICE TRACKING SCREEN
// =============================================================================
void runDeviceTracking() {
  // MQTT handled in main loop
  pruneDevices();

  float hdg = getHeading();
  float roll, pitch;
  getTilt(roll, pitch);
  bool tiltWarn = (fabsf(roll) > TILT_WARN_DEG || fabsf(pitch) > TILT_WARN_DEG);

  while (GPS_SERIAL.available()) gps.encode(GPS_SERIAL.read());

  if (selectedDevice >= nearbyCount) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(0, 20); display.print("Device lost!");
    display.setCursor(0, 32); display.print("Signal timeout");
    display.display();
    delay(2000);
    smoothBearing = -1.0f;
    state = DEVICE_TRACKER; menuIndex = 0;
    return;
  }

  DiscoveredDevice& dev = nearbyDevices[selectedDevice];

  if (!gps.location.isValid()) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(0, 0);  display.print("GPS: searching...");
    display.setCursor(0, 12); display.print("HDG: "); display.print(hdg, 1);
    display.setCursor(0, 24); display.print("TGT: "); display.print(dev.name);
    if (tiltWarn) { display.setCursor(0, 50); display.print("!! TILT !!"); }
    display.display();
    if (btnPressed(BTN_LEFT)) { smoothBearing = -1.0f; state = DEVICE_TRACKER; menuIndex = 0; }
    return;
  }

  // Wait until we have a real position from the target device
  if (dev.lat == 0.0 && dev.lon == 0.0) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(0, 0);  display.print(dev.name);
    display.setCursor(0, 14); display.print("Waiting for their");
    display.setCursor(0, 26); display.print("GPS position...");
    display.setCursor(0, 40); display.print("(They need GPS fix)");
    if (tiltWarn) { display.setCursor(0, 54); display.print("!! TILT !!"); }
    display.display();
    if (btnPressed(BTN_LEFT)) { smoothBearing = -1.0f; state = DEVICE_TRACKER; menuIndex = 0; }
    return;
  }

  float rawBrg  = (float)TinyGPSPlus::courseTo(
                    gps.location.lat(), gps.location.lng(), dev.lat, dev.lon);
  float rawDist = (float)TinyGPSPlus::distanceBetween(
                    gps.location.lat(), gps.location.lng(), dev.lat, dev.lon);

  if (smoothBearing < 0.0f) { smoothBearing = rawBrg; smoothDist = rawDist; }

  smoothBearing = circularEMA(smoothBearing, rawBrg, 0.25f);
  smoothDist    = 0.75f * smoothDist + 0.25f * rawDist;

  float rawRel = smoothBearing - hdg;
  if (rawRel >  180.0f) rawRel -= 360.0f;
  if (rawRel < -180.0f) rawRel += 360.0f;

  float relFor360 = rawRel + 180.0f;
  float sfFor360  = smoothRelAngle + 180.0f;
  sfFor360 = circularEMA(sfFor360, relFor360, 0.25f);
  smoothRelAngle = sfFor360 - 180.0f;

  int frame = relToFrame(smoothRelAngle);

  display.clearDisplay();
  display.drawBitmap(42, 0, frames[frame], FRAME_WIDTH, FRAME_HEIGHT, WHITE);
  display.setTextSize(1);
  display.setCursor(0, 0);  display.print(dev.name);
  display.setCursor(0, 10);
  if (smoothRelAngle >= 0) display.print("+");
  display.print((int)smoothRelAngle); display.print((char)247);
  display.setCursor(0, 50);
  display.print("DST ");
  if (smoothDist >= 1000) { display.print(smoothDist / 1000.0f, 2); display.print("km"); }
  else                    { display.print((int)smoothDist);          display.print("m");  }
  display.setCursor(0, 58);
  display.print("BRG "); display.print((int)smoothBearing); display.print((char)247);
  if (tiltWarn) {
    display.fillRect(0, 18, 38, 10, BLACK);
    display.setCursor(0, 20); display.print("TILT!");
  }
  display.display();
  if (btnPressed(BTN_LEFT)) { smoothBearing = -1.0f; state = DEVICE_TRACKER; menuIndex = 0; }
}



