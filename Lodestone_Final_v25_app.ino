// ─── Paired devices EEPROM ────────────────────────────────────────────────────
// Stores MAC strings of paired devices so pairing survives reboot
// pairedMacs/pairedMacCount declared in global section above

void savePairedDevices() {
  EEPROM.write(PAIRED_EEPROM_ADDR, (uint8_t)pairedMacCount);
  for (int i = 0; i < 10; i++) {
    int addr = PAIRED_EEPROM_ADDR + 1 + i * 20;
    for (int j = 0; j < 20; j++)
      EEPROM.write(addr + j, (uint8_t)(i < pairedMacCount ? pairedMacs[i][j] : 0));
  }
  EEPROM.commit();
}

void loadPairedDevices() {
  pairedMacCount = EEPROM.read(PAIRED_EEPROM_ADDR);
  if (pairedMacCount > 10) pairedMacCount = 0;
  for (int i = 0; i < pairedMacCount; i++) {
    int addr = PAIRED_EEPROM_ADDR + 1 + i * 20;
    for (int j = 0; j < 19; j++)
      pairedMacs[i][j] = (char)EEPROM.read(addr + j);
    pairedMacs[i][19] = '␀';
  }
}

bool isAlreadyPaired(const String& mac) {
  for (int i = 0; i < pairedMacCount; i++)
    if (mac == String(pairedMacs[i])) return true;
  return false;
}

// True if the given nearbyDevices[] entry is a paired hardware Lodestone.
bool isNearbyDevicePaired(int idx) {
  if (idx < 0 || idx >= nearbyCount) return false;
  if (!nearbyDevices[idx].isHardware) return false;
  char mc[20];
  snprintf(mc, sizeof(mc), "%02X%02X%02X%02X%02X%02X",
    nearbyDevices[idx].mac[0],nearbyDevices[idx].mac[1],nearbyDevices[idx].mac[2],
    nearbyDevices[idx].mac[3],nearbyDevices[idx].mac[4],nearbyDevices[idx].mac[5]);
  return isAlreadyPaired(String(mc));
}

void addPairedDevice(const String& mac) {
  if (isAlreadyPaired(mac) || pairedMacCount >= 10) return;
  strncpy(pairedMacs[pairedMacCount], mac.c_str(), 19);
  pairedMacs[pairedMacCount][19] = '␀';
  pairedMacCount++;
  savePairedDevices();
}

void removePairedDevice(const String& mac) {
  for (int i = 0; i < pairedMacCount; i++) {
    if (mac == String(pairedMacs[i])) {
      for (int j = i; j < pairedMacCount-1; j++)
        strncpy(pairedMacs[j], pairedMacs[j+1], 19);
      pairedMacCount--;
      savePairedDevices();
      return;
    }
  }
}

// Re-subscribe to all previously paired device topics
void resubscribePaired() {
  for (int i = 0; i < pairedMacCount; i++) {
    String mac = String(pairedMacs[i]);
    mac.replace(":", "");
    String myClean = myMacStr; myClean.replace(":", "");
    String combined = myClean + "_" + mac;
    mqtt.subscribe(("lodestone/pair/" + combined).c_str());
  }
}


// =============================================================================
//  MSG TARGET SELECT — choose who to send message to
// =============================================================================
void drawMsgTargetSelect() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0); display.print("SEND TO:");
  drawStatusTime();
  display.drawLine(0, 9, 127, 9, WHITE);
  int row = 0;
  // Option 0: Broadcast to all paired
  display.setCursor(0, 13 + row*11);
  display.print(menuIndex == 0 ? "> " : "  ");
  display.print("ALL PAIRED");
  row++;
  // Option 1..appClientCount: individual app clients (paired only)
  int optIdx = 1;
  for (int i = 0; i < appClientCount && row < 5; i++) {
    String cm = String(appClients[i].mac); cm.replace(":","");
    if (!isAlreadyPaired(cm)) { optIdx++; continue; }
    display.setCursor(0, 13 + row*11);
    display.print(menuIndex == optIdx ? "> " : "  ");
    display.print("A:"); display.print(appClients[i].name);
    row++; optIdx++;
  }
  // After app clients: paired hardware Lodestones
  for (int i = 0; i < nearbyCount && row < 5; i++) {
    if (!isNearbyDevicePaired(i)) continue;
    display.setCursor(0, 13 + row*11);
    display.print(menuIndex == optIdx ? "> " : "  ");
    display.print("L:"); display.print(nearbyDevices[i].name);
    row++; optIdx++;
  }
  display.display();
}

// =============================================================================
//  SETUP
// =============================================================================
void setup() {
  Serial.begin(115200);
  GPS_SERIAL.begin(9600, SERIAL_8N1, 16, 17);
  Wire.begin(21, 22);
  EEPROM.begin(EEPROM_SIZE);

  pinMode(BTN_UP,    INPUT_PULLUP);
  pinMode(BTN_DOWN,  INPUT_PULLUP);
  pinMode(BTN_LEFT,  INPUT_PULLUP);
  pinMode(BTN_RIGHT, INPUT_PULLUP);
  pinMode(BTN_PRESS, INPUT_PULLUP);

  display.begin(SCREEN_ADDRESS, true);
  display.setTextColor(WHITE);
  display.clearDisplay();
  display.setTextSize(2);
  display.setCursor(10, 20);
  display.print("Lodestone");
  display.display();
  delay(2000);

  writeReg(LSM303_ACCEL_ADDR, 0x20, 0x27);
  writeReg(LSM303_MAG_ADDR,   0x00, 0x14);
  writeReg(LSM303_MAG_ADDR,   0x01, 0x20);
  writeReg(LSM303_MAG_ADDR,   0x02, 0x00);
  delay(100);

  loadLocations();
  loadWiFiNetworks();
  loadSettings();
  loadPairedDevices();
  if (savedNetworkCount > 0) autoConnectWiFi();
  myMacStr = WiFi.macAddress();
  if (wifiConnected) connectMQTT();

  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(10, 24);
  display.print("Ready.");
  display.display();
  delay(800);
  resetActivity();
}

// =============================================================================
//  LOOP
// =============================================================================
void loop() {

  checkSleep();
  // Wake on any button
  if (!digitalRead(BTN_UP)||!digitalRead(BTN_DOWN)||
      !digitalRead(BTN_LEFT)||!digitalRead(BTN_RIGHT)||
      !digitalRead(BTN_PRESS)) resetActivity();

  if (displaySleeping) { delay(100); return; }

  // ── MQTT maintain ──────────────────────────────────────────────────────────
  if (wifiConnected) {
    if (!mqtt.connected()) {
      static unsigned long lastMqttRetry = 0;
      if (millis() - lastMqttRetry > 10000) {
        lastMqttRetry = millis();
        connectMQTT();
      }
    } else {
      mqttConnected = true;
      mqtt.loop();
      broadcastPosition();
      pruneDevices();
      // Announce every 30 s
      if (millis() - lastAnnounce > 30000) {
        lastAnnounce = millis();
        announcePresence();
      }
    }
  }

  while (GPS_SERIAL.available()) gps.encode(GPS_SERIAL.read());

  // ── MAIN MENU ──────────────────────────────────────────────────────────────
  if (state == MAIN_MENU) {
    drawMainMenu();
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = 5; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex > 5) menuIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      if (menuIndex == 0) { state = DIR_FINDER_MENU;     menuIndex = 0; }
      if (menuIndex == 1) { state = COMPASS; }
      if (menuIndex == 2) { state = DEVICE_TRACKER_MENU; menuIndex = 0; }
      if (menuIndex == 3) { runCalibration(); }
      if (menuIndex == 4) { state = SPEEDOMETER; }
      if (menuIndex == 5) { state = SETTINGS_MENU; menuIndex = 0; }
    }
  }

  // ── DIRECTION FINDER MENU ──────────────────────────────────────────────────
  else if (state == DIR_FINDER_MENU) {
    drawDirFinderMenu();
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = 2; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex > 2) menuIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      if (menuIndex == 0) { state = SELECT_COORD;    menuIndex = 0; }
      if (menuIndex == 1) { state = KEYPAD_NAME;     inputName = ""; charIndex = 0; }
      if (menuIndex == 2) { state = DELETE_LOCATION; menuIndex = 0; }
    }
    if (btnPressed(BTN_LEFT)) { state = MAIN_MENU; menuIndex = 0; }
  }

  // ── DEVICE TRACKER MENU ────────────────────────────────────────────────────
  else if (state == DEVICE_TRACKER_MENU) {
    drawDeviceTrackerMenu();
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = 3; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex > 3) menuIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      if (menuIndex == 0) { state = DEVICE_TRACKER;  menuIndex = 0; }
      if (menuIndex == 1) { state = PAIR_LODESTONE;  menuIndex = 0; }
      if (menuIndex == 2) { state = CONNECT_APP;     menuIndex = 0; }
      if (menuIndex == 3) { state = MSG_INBOX;       menuIndex = 0; }
    }
    if (btnPressed(BTN_LEFT)) { state = MAIN_MENU; menuIndex = 0; }
  }

  // ── SELECT COORD ───────────────────────────────────────────────────────────
  else if (state == SELECT_COORD) {
    drawLocationList("SELECT TARGET");
    if (locationCount == 0) {
      if (btnPressed(BTN_LEFT)) { state = DIR_FINDER_MENU; menuIndex = 0; }
      return;
    }
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = locationCount - 1; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex >= locationCount) menuIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      TARGET_LAT = locations[menuIndex].lat;
      TARGET_LON = locations[menuIndex].lon;
      strncpy(TARGET_NAME, locations[menuIndex].name, 15);
      TARGET_NAME[15] = '\0';
      navActive  = true;
      state      = NAVIGATING;
    }
    if (btnPressed(BTN_LEFT)) { state = DIR_FINDER_MENU; menuIndex = 0; }
  }

  // ── DELETE LOCATION ────────────────────────────────────────────────────────
  else if (state == DELETE_LOCATION) {
    drawLocationList("DELETE LOCATION");
    if (locationCount == 0) {
      if (btnPressed(BTN_LEFT)) { state = DIR_FINDER_MENU; menuIndex = 0; }
      return;
    }
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = locationCount - 1; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex >= locationCount) menuIndex = 0; }
    if (btnPressed(BTN_PRESS) && locationCount > 0) {
      state = DELETE_CONFIRM;
    }
    if (btnPressed(BTN_LEFT)) { state = DIR_FINDER_MENU; menuIndex = 0; }
  }

  // ── DELETE CONFIRM ─────────────────────────────────────────────────────────
  else if (state == DELETE_CONFIRM) {
    drawDeleteConfirm(locations[menuIndex].name);
    if (btnPressed(BTN_PRESS)) {
      for (int i = menuIndex; i < locationCount - 1; i++)
        locations[i] = locations[i + 1];
      locationCount--;
      saveLocations();
      if (menuIndex >= locationCount && menuIndex > 0) menuIndex--;
      state = DELETE_LOCATION;
    }
    if (btnPressed(BTN_LEFT)) { state = DELETE_LOCATION; }
  }

  // ── KEYPAD NAME ────────────────────────────────────────────────────────────
  else if (state == KEYPAD_NAME) {
    drawNameInput();
    if (btnPressed(BTN_UP))    { charIndex++; if (charIndex >= (int)sizeof(nameChars) - 1) charIndex = 0; }
    if (btnPressed(BTN_DOWN))  { charIndex--; if (charIndex < 0) charIndex = sizeof(nameChars) - 2; }
    if (btnPressed(BTN_PRESS)) {
      if (inputName.length() < 15) inputName += nameChars[charIndex];
    }
    if (btnPressed(BTN_LEFT))  {
      if (inputName.length() > 0) inputName.remove(inputName.length() - 1);
      else { state = DIR_FINDER_MENU; menuIndex = 0; }
    }
    if (btnPressed(BTN_RIGHT)) {
      // Validate: must not be empty
      if (inputName.length() == 0) {
        saveErrorMsg = "Name cannot be empty.";
        state = SAVE_ERROR;
      } else {
        // Check for duplicate name
        bool dup = false;
        for (int i = 0; i < locationCount; i++) {
          if (inputName.equalsIgnoreCase(locations[i].name)) { dup = true; break; }
        }
        if (dup) {
          saveErrorMsg = "Name already exists.";
          state = SAVE_ERROR;
        } else {
          coordInput = ""; numIndex = 0; state = INPUT_LAT;
        }
      }
    }
  }

  // ── INPUT LAT ──────────────────────────────────────────────────────────────
  else if (state == INPUT_LAT) {
    drawCoordInput("LATITUDE");
    if (btnPressed(BTN_UP))    { numIndex++; if (numIndex >= (int)sizeof(numChars) - 1) numIndex = 0; }
    if (btnPressed(BTN_DOWN))  { numIndex--; if (numIndex < 0) numIndex = sizeof(numChars) - 2; }
    if (btnPressed(BTN_PRESS)) { coordInput += numChars[numIndex]; }
    if (btnPressed(BTN_LEFT))  {
      if (coordInput.length() > 0) coordInput.remove(coordInput.length() - 1);
      else { state = KEYPAD_NAME; }
    }
    if (btnPressed(BTN_RIGHT)) {
      if (coordInput.length() == 0) {
        saveErrorMsg = "Latitude is empty.";
        state = SAVE_ERROR;
      } else {
        tempLat = coordInput.toDouble();
        coordInput = ""; numIndex = 0; state = INPUT_LON;
      }
    }
  }

  // ── INPUT LON ──────────────────────────────────────────────────────────────
  else if (state == INPUT_LON) {
    drawCoordInput("LONGITUDE");
    if (btnPressed(BTN_UP))    { numIndex++; if (numIndex >= (int)sizeof(numChars) - 1) numIndex = 0; }
    if (btnPressed(BTN_DOWN))  { numIndex--; if (numIndex < 0) numIndex = sizeof(numChars) - 2; }
    if (btnPressed(BTN_PRESS)) { coordInput += numChars[numIndex]; }
    if (btnPressed(BTN_LEFT))  {
      if (coordInput.length() > 0) coordInput.remove(coordInput.length() - 1);
      else { coordInput = ""; numIndex = 0; state = INPUT_LAT; }
    }
    if (btnPressed(BTN_RIGHT)) {
      if (coordInput.length() == 0) {
        saveErrorMsg = "Longitude is empty.";
        state = SAVE_ERROR;
      } else {
        tempLon = coordInput.toDouble();
        state = SAVE_CONFIRM;
      }
    }
  }

  // ── SAVE CONFIRM ─────────────────────────────────────────────────────────────────────────
  else if (state == SAVE_CONFIRM) {
    drawSaveConfirm();
    if (btnPressed(BTN_PRESS)) {
      if (locationCount < 10) {
        strncpy(locations[locationCount].name, inputName.c_str(), 15);
        locations[locationCount].name[15] = '\0';
        locations[locationCount].lat = tempLat;
        locations[locationCount].lon = tempLon;
        locationCount++;
        saveLocations();
      }
      state = DIR_FINDER_MENU; menuIndex = 0;
    }
    if (btnPressed(BTN_LEFT)) { coordInput = ""; numIndex = 0; state = INPUT_LON; }
  }

  // ── SAVE ERROR ───────────────────────────────────────────────────────────────────────────
  else if (state == SAVE_ERROR) {
    drawSaveError();
    if (btnPressed(BTN_PRESS) || btnPressed(BTN_LEFT)) {
      if (saveErrorMsg.startsWith("Name")) state = KEYPAD_NAME;
      else if (saveErrorMsg.startsWith("Lat")) state = INPUT_LAT;
      else state = INPUT_LON;
    }
  }

  // ── NAVIGATING ─────────────────────────────────────────────────────────────
  else if (state == NAVIGATING) {
    runNavigation();
    delay(200);
  }

  // ── COMPASS ────────────────────────────────────────────────────────────────
  else if (state == COMPASS) {
    runDigitalCompass();
    delay(200);
  }

  // ── WIFI SCAN ──────────────────────────────────────────────────────────────
  else if (state == WIFI_SCAN) {
    drawWiFiScan();
    if (btnPressed(BTN_UP))   { networkIndex--; if (networkIndex < 0) networkIndex = networkCount - 1; }
    if (btnPressed(BTN_DOWN)) { networkIndex++; if (networkIndex >= networkCount) networkIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      // Find or create slot for this SSID
      pendingNetworkIdx = -1;
      for (int _i=0; _i<savedNetworkCount; _i++)
        if (strcmp(savedNetworks[_i].ssid, scannedSSIDs[networkIndex].c_str())==0)
          { pendingNetworkIdx = _i; break; }
      if (pendingNetworkIdx == -1) {
        pendingNetworkIdx = (savedNetworkCount < MAX_SAVED_WIFI) ? savedNetworkCount : MAX_SAVED_WIFI-1;
      }
      strncpy(savedNetworks[pendingNetworkIdx].ssid, scannedSSIDs[networkIndex].c_str(), 31);
      savedNetworks[pendingNetworkIdx].ssid[31] = '\0';
      // If already saved, reconnect directly without re-entering password
      if (pendingNetworkIdx < savedNetworkCount &&
          strlen(savedNetworks[pendingNetworkIdx].password) > 0) {
        activeNetworkIdx = pendingNetworkIdx;
        connectNetworkByIndex(pendingNetworkIdx);
        state = SETTINGS_MENU; menuIndex = 0;
      } else {
        menuIndex = 0;
        state = WIFI_TYPE_SELECT;
      }
    }
    if (btnPressed(BTN_LEFT)) { state = SETTINGS_MENU; menuIndex = 0; }
    delay(150);
  }

  // ── WIFI TYPE SELECT ───────────────────────────────────────────────────────
  else if (state == WIFI_TYPE_SELECT) {
    drawWiFiTypeSelect();
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = 1; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex > 1) menuIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      if (menuIndex == 0) {
        // Personal — skip username
        savedNetworks[pendingNetworkIdx].enterprise = false;
        memset(savedNetworks[pendingNetworkIdx].username, 0, 32);
        inputPassword = ""; charIndex = 0; activeSet = CAPS;
        state = WIFI_SETUP_PASS;
      } else {
        // Enterprise LDAP — collect username first
        savedNetworks[pendingNetworkIdx].enterprise = true;
        inputUsername = ""; charIndex = 0; activeSet = LOWER;
        state = WIFI_SETUP_USER;
      }
    }
    if (btnPressed(BTN_LEFT)) { state = WIFI_SCAN; menuIndex = 0; }
  }

  // ── WIFI USERNAME (LDAP) ───────────────────────────────────────────────────
  else if (state == WIFI_SETUP_USER) {
    drawTextInput("LDAP Username:", inputUsername, false);

    int len = getCurrentCharsLen();
    int totalLen = (activeSet == SPECIAL) ? len + 1 : len;

    if (btnPressed(BTN_UP))   { charIndex++; if (charIndex >= totalLen) charIndex = 0; }
    if (btnPressed(BTN_DOWN)) { charIndex--; if (charIndex < 0) charIndex = totalLen - 1; }

    if (btnPressed(BTN_PRESS)) {
      if (activeSet == SPECIAL && charIndex >= len) {
        // DONE — save username, move to password
        strncpy(savedNetworks[pendingNetworkIdx].username, inputUsername.c_str(), 31);
        savedNetworks[pendingNetworkIdx].username[31] = '\0';
        inputPassword = ""; charIndex = 0; activeSet = CAPS;
        state = WIFI_SETUP_PASS;
      } else {
        inputUsername += getCurrentChars()[charIndex];
      }
    }
    if (btnPressed(BTN_LEFT)) {
      if (inputUsername.length() > 0) inputUsername.remove(inputUsername.length() - 1);
      else { activeSet = CAPS; charIndex = 0; state = WIFI_TYPE_SELECT; menuIndex = 0; }
    }
    if (btnPressed(BTN_RIGHT)) {
      switch (activeSet) {
        case CAPS:    activeSet = LOWER;   break;
        case LOWER:   activeSet = DIGITS;  break;
        case DIGITS:  activeSet = SPECIAL; break;
        case SPECIAL: activeSet = CAPS;    break;
      }
      charIndex = 0;
    }
  }

  // ── WIFI PASSWORD ──────────────────────────────────────────────────────────
  else if (state == WIFI_SETUP_PASS) {
    drawTextInput("WiFi Password:", inputPassword, true);

    int len = getCurrentCharsLen();
    int totalLen = (activeSet == SPECIAL) ? len + 1 : len;

    if (btnPressed(BTN_UP))   { charIndex++; if (charIndex >= totalLen) charIndex = 0; }
    if (btnPressed(BTN_DOWN)) { charIndex--; if (charIndex < 0) charIndex = totalLen - 1; }

    if (btnPressed(BTN_PRESS)) {
      if (activeSet == SPECIAL && charIndex >= len) {
        // DONE — save and connect
        // Save into savedNetworks slot (ssid already stored in pendingNetworkIdx slot)
        strncpy(savedNetworks[pendingNetworkIdx].password, inputPassword.c_str(), 63);
        savedNetworks[pendingNetworkIdx].password[63] = '\0';
        // Add to saved list if new
        bool found = false;
        for (int _i=0; _i<savedNetworkCount; _i++)
          if (strcmp(savedNetworks[_i].ssid, savedNetworks[pendingNetworkIdx].ssid)==0 && _i!=pendingNetworkIdx) { found=true; break; }
        if (!found && savedNetworkCount <= pendingNetworkIdx)
          savedNetworkCount = pendingNetworkIdx + 1;
        saveWiFiNetworks();
        activeNetworkIdx = pendingNetworkIdx;
        connectNetworkByIndex(pendingNetworkIdx);
        activeSet = CAPS; charIndex = 0;
        state = SETTINGS_MENU; menuIndex = 0;
      } else {
        inputPassword += getCurrentChars()[charIndex];
      }
    }
    if (btnPressed(BTN_LEFT)) {
      if (inputPassword.length() > 0) inputPassword.remove(inputPassword.length() - 1);
      else { activeSet = CAPS; charIndex = 0; state = WIFI_TYPE_SELECT; menuIndex = 0; }
    }
    if (btnPressed(BTN_RIGHT)) {
      switch (activeSet) {
        case CAPS:    activeSet = LOWER;   break;
        case LOWER:   activeSet = DIGITS;  break;
        case DIGITS:  activeSet = SPECIAL; break;
        case SPECIAL: activeSet = CAPS;    break;
      }
      charIndex = 0;
    }
  }


  // ── SPEEDOMETER ────────────────────────────────────────────────────────────
  else if (state == SPEEDOMETER) {
    runSpeedometer();
    delay(200);
  }

  // ── DEVICE NAME INPUT ──────────────────────────────────────────────────────
  else if (state == DEVICE_NAME_INPUT) {
    // Reuse drawNameInput screen
    drawNameInput();
    if (btnPressed(BTN_UP))    { charIndex++; if (charIndex >= (int)sizeof(nameChars)-1) charIndex = 0; }
    if (btnPressed(BTN_DOWN))  { charIndex--; if (charIndex < 0) charIndex = sizeof(nameChars)-2; }
    if (btnPressed(BTN_PRESS)) {
      if (inputName.length() < 15) inputName += nameChars[charIndex];
    }
    if (btnPressed(BTN_LEFT)) {
      if (inputName.length() > 0) inputName.remove(inputName.length()-1);
      else { state = SETTINGS_MENU; menuIndex = 2; }
    }
    if (btnPressed(BTN_RIGHT)) {
      if (inputName.length() > 0) {
        strncpy(deviceName, inputName.c_str(), 31);
        deviceName[31] = '\0';
        saveSettings();
        announcePresence();   // broadcast new name immediately
        state = SETTINGS_MENU; menuIndex = 2;
      }
    }
  }


  // ── CONNECT APP ────────────────────────────────────────────────────────────
  else if (state == CONNECT_APP) {
    drawConnectApp();
    if (appClientCount > 0) {
      if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = appClientCount-1; }
      if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex >= appClientCount) menuIndex = 0; }
      if (btnPressed(BTN_PRESS)) {
        // Send pair request to selected app client
        if (mqtt.connected() && menuIndex < appClientCount) {
          String cleanMac = String(appClients[menuIndex].mac);
          cleanMac.replace(":", "");
          String topic = "lodestone/request/" + cleanMac;
          char myClean[20];
          String tmp = myMacStr; tmp.replace(":", "");
          tmp.toCharArray(myClean, sizeof(myClean));
          char payload[128];
          snprintf(payload, sizeof(payload),
            "{\"name\":\"%s\",\"mac\":\"%s\",\"type\":\"hardware\"}",
            deviceName, myClean);
          mqtt.publish(topic.c_str(), payload);
          display.clearDisplay();
          display.setTextSize(1);
          display.setCursor(0, 20); display.print("Request sent to:");
          display.setCursor(0, 34); display.print(appClients[menuIndex].name);
          display.display();
          delay(1500);
        }
      }
    }
    if (btnPressed(BTN_LEFT)) { state = DEVICE_TRACKER_MENU; menuIndex = 1; }
    delay(150);
  }

  // ── MSG INBOX ───────────────────────────────────────────────────────────────
  else if (state == MSG_INBOX) {
    drawMsgInbox();
    if (btnPressed(BTN_PRESS)) {
      // Go to target selection first
      menuIndex = 0;
      msgTarget = -1;  // default broadcast
      state = MSG_TARGET_SELECT;
    }
    if (btnPressed(BTN_LEFT)) { state = DEVICE_TRACKER_MENU; menuIndex = 2; }
    delay(150);
  }

  // ── MSG TARGET SELECT ──────────────────────────────────────────────────────
  else if (state == MSG_TARGET_SELECT) {
    drawMsgTargetSelect();
    // count paired hardware targets
    int _pairedHw = 0;
    for (int i = 0; i < nearbyCount; i++) if (isNearbyDevicePaired(i)) _pairedHw++;
    int maxOpts = 1 + appClientCount + _pairedHw;  // broadcast + apps + paired hw
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = maxOpts-1; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex >= maxOpts) menuIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      msgTarget = menuIndex - 1;  // -1=broadcast, 0..N=client index
      composeMsgLen = 0;
      memset(composeMsg, 0, sizeof(composeMsg));
      charIndex = 0;
      state = MSG_COMPOSE;
    }
    if (btnPressed(BTN_LEFT)) { state = MSG_INBOX; }
    delay(150);
  }

  // ── MSG COMPOSE ─────────────────────────────────────────────────────────────
  else if (state == MSG_COMPOSE) {
    drawMsgCompose();
    if (btnPressed(BTN_UP))   { charIndex++; if (charIndex >= (int)sizeof(nameChars)-1) charIndex = 0; }
    if (btnPressed(BTN_DOWN)) { charIndex--; if (charIndex < 0) charIndex = sizeof(nameChars)-2; }
    if (btnPressed(BTN_PRESS)) {
      if (composeMsgLen < 50) {
        composeMsg[composeMsgLen++] = nameChars[charIndex];
        composeMsg[composeMsgLen] = '\0';
      }
    }
    if (btnPressed(BTN_LEFT)) {
      if (composeMsgLen > 0) { composeMsgLen--; composeMsg[composeMsgLen] = '\0'; }
      else { state = MSG_INBOX; }
    }
    if (btnPressed(BTN_RIGHT) && composeMsgLen > 0 && mqtt.connected()) {
      char myClean[20];
      String tmp = myMacStr; tmp.replace(":", "");
      tmp.toCharArray(myClean, sizeof(myClean));
      char payload[256];
      snprintf(payload, sizeof(payload),
        "{\"from\":\"%s\",\"mac\":\"%s\",\"msg\":\"%s\"}",
        deviceName, myClean, composeMsg);

      if (msgTarget == -1) {
        // Broadcast — send only to currently paired devices/apps
        // via each peer's personal inbox topic. No global broadcast.
        for (int _p = 0; _p < pairedMacCount; _p++) {
          String _t = "lodestone/msg/" + String(pairedMacs[_p]);
          mqtt.publish(_t.c_str(), payload);
        }
      } else if (msgTarget >= 0 && msgTarget < appClientCount) {
        // Targeted send to an app client — but only if paired
        String clientMac = String(appClients[msgTarget].mac);
        clientMac.replace(":", "");
        if (!isAlreadyPaired(clientMac)) {
          display.clearDisplay();
          display.setTextSize(1);
          display.setCursor(0, 20); display.print("Not paired with:");
          display.setCursor(0, 34); display.print(appClients[msgTarget].name);
          display.display(); delay(1500);
          state = MSG_TARGET_SELECT; return;
        }
        String topic = "lodestone/msg/" + clientMac;
        mqtt.publish(topic.c_str(), payload);
      } else {
        // Targeted send to a paired hardware Lodestone
        int hwIdx = msgTarget - appClientCount;
        int seen = 0; int realIdx = -1;
        for (int i = 0; i < nearbyCount; i++) {
          if (isNearbyDevicePaired(i)) { if (seen == hwIdx) { realIdx = i; break; } seen++; }
        }
        if (realIdx >= 0) {
          char mc[20];
          snprintf(mc, sizeof(mc), "%02X%02X%02X%02X%02X%02X",
            nearbyDevices[realIdx].mac[0],nearbyDevices[realIdx].mac[1],nearbyDevices[realIdx].mac[2],
            nearbyDevices[realIdx].mac[3],nearbyDevices[realIdx].mac[4],nearbyDevices[realIdx].mac[5]);
          String topic = "lodestone/msg/" + String(mc);
          mqtt.publish(topic.c_str(), payload);
        }
      }

      // Add to own inbox as sent
      if (inboxCount < 5) inboxCount++;
      for (int i = inboxCount-1; i > 0; i--) strncpy(inboxMsgs[i], inboxMsgs[i-1], 63);
      char sentLine[64];
      char _hwName[16] = "?";
      if (msgTarget >= appClientCount && msgTarget < appClientCount + nearbyCount) {
        int hwIdx = msgTarget - appClientCount;
        int seen = 0;
        for (int i = 0; i < nearbyCount; i++) {
          if (isNearbyDevicePaired(i)) {
            if (seen == hwIdx) { strncpy(_hwName, nearbyDevices[i].name, 15); _hwName[15]=0; break; }
            seen++;
          }
        }
      }
      const char* toName = (msgTarget == -1) ? "All paired" :
                           (msgTarget < appClientCount ? appClients[msgTarget].name : _hwName);
      snprintf(sentLine, sizeof(sentLine), "Me->%s: %s", toName, composeMsg);
      strncpy(inboxMsgs[0], sentLine, 63);
      composeMsgLen = 0; memset(composeMsg, 0, sizeof(composeMsg));
      display.clearDisplay();
      display.setTextSize(1);
      display.setCursor(10, 20); display.print("Sent to:");
      display.setCursor(10, 34); display.print(toName);
      display.display(); delay(1000);
      state = MSG_INBOX;
    }
    delay(150);
  }

  // ── PAIR REQUEST ───────────────────────────────────────────────────────────
  else if (state == PAIR_REQUEST) {
    drawPairRequest();
    if (btnPressed(BTN_PRESS)) {
      // Accept — save pairing and publish accept
      String cleanPeerMac = pendingPairMac; cleanPeerMac.replace(":", "");
      addPairedDevice(cleanPeerMac);  // persist to EEPROM
      String acceptTopic = "lodestone/accept/" + cleanPeerMac;
      char accBuf[128];
      snprintf(accBuf, sizeof(accBuf), "{\"name\":\"%s\",\"mac\":\"%s\"}", deviceName, myMacStr.c_str());
      mqtt.publish(acceptTopic.c_str(), accBuf);
      // Subscribe to shared pair topic
      // Subscribe to shared pair topic
      String myClean2 = myMacStr; myClean2.replace(":", "");
      String peerClean = pendingPairMac; peerClean.replace(":", "");
      String pairTopicStr = "lodestone/pair/" + myClean2 + "_" + peerClean;
      mqtt.subscribe(pairTopicStr.c_str());
      display.clearDisplay();
      display.setTextSize(1);
      display.setCursor(10, 24); display.print("Paired with");
      display.setCursor(10, 36); display.print(pendingPairName);
      display.display();
      delay(1500);
      state = MAIN_MENU; menuIndex = 0;
    }
    if (btnPressed(BTN_LEFT)) {
      state = MAIN_MENU; menuIndex = 0;
    }
  }

  // ── SETTINGS MENU ──────────────────────────────────────────────────────────
  else if (state == SETTINGS_MENU) {
    drawSettingsMenu();
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = 4; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex > 4) menuIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      if (menuIndex == 0) {           // WiFi Setup
        networkIndex = 0;
        scanNetworks();
        if (networkCount > 0) {
          state = WIFI_SCAN;
        } else {
          display.clearDisplay();
          display.setTextSize(1);
          display.setCursor(0, 16); display.print("No networks found.");
          display.setCursor(0, 30); display.print("Check WiFi antenna");
          display.setCursor(0, 44); display.print("or move closer.");
          display.display();
          delay(2000);
        }
      }
      if (menuIndex == 1) {           // Disconnect WiFi
        if (wifiConnected) {
          WiFi.disconnect(true);
          wifiConnected = false;
          display.clearDisplay();
          display.setTextSize(1);
          display.setCursor(16, 20); display.print("WiFi disconnected");
          display.display();
          delay(1500);
        }
      }
      if (menuIndex == 2) {           // Device Name
        inputName = String(deviceName);
        charIndex = 0;
        state = DEVICE_NAME_INPUT;
      }
      if (menuIndex == 3) {           // Bluetooth (placeholder)
        display.clearDisplay();
        display.setTextSize(1);
        display.setCursor(10, 20); display.print("BT: Coming soon");
        display.setCursor(10, 34); display.print("(MQTT app ready)");
        display.display();
        delay(2000);
      }
      if (menuIndex == 4) {           // Sleep time
        const uint8_t opts[] = {0,1,2,5};
        menuIndex = 0;
        for (int i=0;i<4;i++) if(opts[i]==sleepTimeoutMin) menuIndex=i;
        state = SLEEP_SET;
      }
    }
    if (btnPressed(BTN_LEFT)) { state = MAIN_MENU; menuIndex = 0; }
  }

  // ── SLEEP SET ──────────────────────────────────────────────────────────────
  else if (state == SLEEP_SET) {
    drawSleepSet();
    const uint8_t opts[] = {0, 1, 2, 5};
    if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = 4; }
    if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex > 4) menuIndex = 0; }
    if (btnPressed(BTN_PRESS)) {
      sleepTimeoutMin = opts[menuIndex];
      saveSettings();
      menuIndex = 4;
      state = SETTINGS_MENU;
    }
    if (btnPressed(BTN_LEFT)) { menuIndex = 4; state = SETTINGS_MENU; }
  }

  // ── DEVICE TRACKER ─────────────────────────────────────────────────────────
  // ── PAIR LODESTONE ─────────────────────────────
  else if (state == PAIR_LODESTONE) {
    drawPairLodestone();
    // Build list of unpaired hardware indices
    int unpIdx[MAX_DEVICES]; int unpN = 0;
    for (int i = 0; i < nearbyCount; i++) {
      if (nearbyDevices[i].isHardware && !isNearbyDevicePaired(i)) {
        if (unpN < MAX_DEVICES) unpIdx[unpN++] = i;
      }
    }
    if (unpN > 0) {
      if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = unpN - 1; }
      if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex >= unpN) menuIndex = 0; }
      if (btnPressed(BTN_PRESS) && mqtt.connected()) {
        int idx = unpIdx[menuIndex];
        char peerClean[20];
        snprintf(peerClean, sizeof(peerClean), "%02X%02X%02X%02X%02X%02X",
          nearbyDevices[idx].mac[0],nearbyDevices[idx].mac[1],nearbyDevices[idx].mac[2],
          nearbyDevices[idx].mac[3],nearbyDevices[idx].mac[4],nearbyDevices[idx].mac[5]);
        String topic = "lodestone/request/" + String(peerClean);
        char myClean[20];
        String tmp = myMacStr; tmp.replace(":", "");
        tmp.toCharArray(myClean, sizeof(myClean));
        char payload[128];
        snprintf(payload, sizeof(payload),
          "{\"name\":\"%s\",\"mac\":\"%s\",\"type\":\"hardware\"}",
          deviceName, myClean);
        mqtt.publish(topic.c_str(), payload);
        display.clearDisplay();
        display.setTextSize(1);
        display.setCursor(0, 20); display.print("Request sent to:");
        display.setCursor(0, 34); display.print(nearbyDevices[idx].name);
        display.display();
        delay(1500);
      }
    }
    if (btnPressed(BTN_LEFT)) { state = DEVICE_TRACKER_MENU; menuIndex = 1; }
    delay(150);
  }

  else if (state == DEVICE_TRACKER) {
    drawDeviceTracker();
    // Build visible-row -> nearbyDevices[] index map
    int vmap[MAX_DEVICES]; int vn = 0;
    for (int i = 0; i < nearbyCount; i++) if (isNearbyDevicePaired(i)) { if (vn<MAX_DEVICES) vmap[vn++] = i; }
    if (wifiConnected && vn > 0) {
      if (btnPressed(BTN_UP))   { menuIndex--; if (menuIndex < 0) menuIndex = vn - 1; }
      if (btnPressed(BTN_DOWN)) { menuIndex++; if (menuIndex >= vn) menuIndex = 0; }
      if (btnPressed(BTN_PRESS)) { selectedDevice = vmap[menuIndex]; state = DEVICE_TRACKING; }
      if (btnPressed(BTN_RIGHT)) { selectedDevice = vmap[menuIndex]; state = UNPAIR_CONFIRM; }
    }
    if (btnPressed(BTN_LEFT)) { state = DEVICE_TRACKER_MENU; menuIndex = 0; }
    delay(200);
  }

  // UNPAIR CONFIRM
  else if (state == UNPAIR_CONFIRM) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(WHITE);
    display.setCursor(0, 0); display.print("UNPAIR?");
    display.drawLine(0, 10, 127, 10, WHITE);
    display.setCursor(0, 18); display.print(nearbyDevices[selectedDevice].name);
    display.setCursor(0, 36); display.print("PRESS = confirm");
    display.setCursor(0, 48); display.print("LEFT  = cancel");
    display.display();
    if (btnPressed(BTN_PRESS)) {
      char mc[20];
      snprintf(mc, sizeof(mc), "%02X%02X%02X%02X%02X%02X",
        nearbyDevices[selectedDevice].mac[0],nearbyDevices[selectedDevice].mac[1],
        nearbyDevices[selectedDevice].mac[2],nearbyDevices[selectedDevice].mac[3],
        nearbyDevices[selectedDevice].mac[4],nearbyDevices[selectedDevice].mac[5]);
      String peer = String(mc);
      removePairedDevice(peer);
      String myClean = myMacStr; myClean.replace(":", "");
      mqtt.unsubscribe(("lodestone/pair/" + myClean + "_" + peer).c_str());
      mqtt.unsubscribe(("lodestone/pair/" + peer + "_" + myClean).c_str());
      char pl[96];
      snprintf(pl, sizeof(pl), "{\"mac\":\"%s\",\"name\":\"%s\"}", myClean.c_str(), deviceName);
      mqtt.publish(("lodestone/unpair/" + peer).c_str(), pl);
      display.clearDisplay();
      display.setCursor(10, 28); display.print("Unpaired.");
      display.display(); delay(1000);
      state = DEVICE_TRACKER; menuIndex = 0;
    }
    if (btnPressed(BTN_LEFT)) { state = DEVICE_TRACKER; }
    delay(150);
  }

  // ── DEVICE TRACKING ────────────────────────────────────────────────────────
  else if (state == DEVICE_TRACKING) {
    runDeviceTracking();
    delay(200);
  }
}
