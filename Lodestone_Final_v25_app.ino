// ─── Status bar time (top-right, every screen) ────────────────────────────────
// Draw WiFi signal bars at given x position, y=0 row
void drawWiFiBars(int x) {
  if (!wifiConnected) return;
  int rssi = WiFi.RSSI();
  int bars = 0;
  if      (rssi >= -55) bars = 3;
  else if (rssi >= -70) bars = 2;
  else if (rssi >= -85) bars = 1;
  for (int b = 0; b < 3; b++) {
    int bx = x + b * 6;
    int bh = 2 + b * 2;
    if (b < bars) display.fillRect(bx, 7 - bh, 4, bh, WHITE);
    else          display.drawRect(bx, 7 - bh, 4, bh, WHITE);
  }
}

void drawStatusTime() {
  // Time only — no WiFi bars here (bars shown on main menu only)
  if (!gps.time.isValid()) return;
  int totalMin = gps.time.hour() * 60 + gps.time.minute() + 330;
  totalMin %= (24 * 60);
  if (totalMin < 0) totalMin += 24 * 60;
  char buf[6];
  snprintf(buf, sizeof(buf), "%02d:%02d", totalMin / 60, totalMin % 60);
  display.setTextSize(1);
  display.setCursor(98, 0);
  display.print(buf);
}

void drawMainMenu() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);

  // Header: title left | wifi bars centre | time right | separator
  display.setCursor(0, 0);
  display.print("LODESTONE");
  drawWiFiBars(68);   // bars between title and time, x=68..90
  drawStatusTime();   // time at x=98
  display.drawLine(0, 9, 127, 9, WHITE);

  // Scrollable list — 4 rows visible, 13px each, starting at y=12
  const int totalItems  = 6;   // now includes SPEEDOMETER
  const int visibleRows = 4;
  int startItem = 0;
  if (menuIndex >= visibleRows) startItem = menuIndex - visibleRows + 1;

  for (int i = 0; i < visibleRows; i++) {
    int item = startItem + i;
    if (item >= totalItems) break;
    display.setCursor(0, 12 + i * 13);
    display.print(item == menuIndex ? "> " : "  ");
    display.print(menuItems[item]);
  }

  display.display();
}

