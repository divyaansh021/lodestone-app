  display.drawLine(0, 9, 127, 9, WHITE);

  String shown = "";
  if (isPassword) {
    for (int i = 0; i < (int)currentText.length(); i++) shown += "*";
  } else {
    shown = currentText;
  }
  display.setCursor(0, 12); display.print(shown); display.print("_");

  // Current char — large, centred
  display.setTextSize(2);
  int len = getCurrentCharsLen();
  bool isDone = (activeSet == SPECIAL && charIndex >= len);
  if (isDone) {
    display.setCursor(30, 26); display.print("SAVE");
  } else {
    char selChar[2] = { getCurrentChars()[charIndex], 0 };
    int cx = (128 - 12) / 2;
    display.setCursor(cx, 26);
    display.print(selChar);
  }
  display.setTextSize(1);

  // Charset indicator top-right
  display.setCursor(96, 12);
  switch (activeSet) {
    case CAPS:    display.print("[ABC]"); break;
    case LOWER:   display.print("[abc]"); break;
    case DIGITS:  display.print("[123]"); break;
    case SPECIAL: display.print("[!@#]"); break;
  }

  display.display();
}


