void drawWiFiScan() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0); display.print("Select Network:");
  drawStatusTime();
  display.drawLine(0, 9, 127, 9, WHITE);

  // Scrollable: 4 rows visible, 13px each starting at y=12
  const int visRows = 4;
  int startNet = 0;
  if (networkIndex >= visRows) startNet = networkIndex - visRows + 1;

  for (int i = 0; i < visRows; i++) {
    int idx = startNet + i;
    if (idx >= networkCount) break;
    int y = 12 + i * 13;
    display.setCursor(0, y);
    display.print(idx == networkIndex ? "> " : "  ");
    String ssid = scannedSSIDs[idx];
    if (ssid.length() > 14) ssid = ssid.substring(0, 14);
    display.print(ssid);
    // Signal strength bars (3 bars, rightmost 18px)
    int rssi = scannedRSSI[idx];
    int bars = 0;
    if      (rssi >= -55) bars = 3;
    else if (rssi >= -70) bars = 2;
    else if (rssi >= -85) bars = 1;
    for (int b = 0; b < 3; b++) {
      int bx = 110 + b * 6;
      int bh = 3 + b * 3;
      if (b < bars) display.fillRect(bx, y + 8 - bh, 4, bh, WHITE);
      else          display.drawRect(bx, y + 8 - bh, 4, bh, WHITE);
    }
  }
  // (scroll indicator removed)
  display.display();
}

