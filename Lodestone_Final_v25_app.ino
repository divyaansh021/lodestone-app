  else sleepTimeoutMin = 1;
  if (s.deviceName[0] >= 32 && s.deviceName[0] <= 126)
    strncpy(deviceName, s.deviceName, 31);
}

// ─── Sensor fusion state ──────────────────────────────────────────────────────
float filteredHeading = 0.0f;

// Accelerometer median filter (3-sample)
#define ACCEL_MEDIAN_N 3
float accelBufX[ACCEL_MEDIAN_N] = {0};
float accelBufY[ACCEL_MEDIAN_N] = {0};
float accelBufZ[ACCEL_MEDIAN_N] = {0};
uint8_t accelBufIdx = 0;

// Smoothed roll/pitch for tilt compensation
float smoothRoll  = 0.0f;
float smoothPitch = 0.0f;

// Smoothed navigation outputs
float smoothBearing  = -1.0f;   // -1 = uninitialised
float smoothDist     = -1.0f;
float smoothRelAngle = 0.0f;

// =============================================================================
//  LSM303 LOW-LEVEL
// =============================================================================
void writeReg(uint8_t addr, uint8_t reg, uint8_t val) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write(val);
  Wire.endTransmission();
}

void readAccelRaw(float &ax, float &ay, float &az) {
  Wire.beginTransmission(LSM303_ACCEL_ADDR);
  Wire.write(0x28 | 0x80);
  Wire.endTransmission(false);
  Wire.requestFrom(LSM303_ACCEL_ADDR, (uint8_t)6);
  int16_t rawX = (Wire.read() | (Wire.read() << 8));
  int16_t rawY = (Wire.read() | (Wire.read() << 8));
  int16_t rawZ = (Wire.read() | (Wire.read() << 8));
  ax = rawX * 0.001f;
  ay = rawY * 0.001f;
  az = rawZ * 0.001f;
}

// Median of 3 helper
static float med3(float a, float b, float c) {
  if (a > b) { float t = a; a = b; b = t; }
  if (b > c) { float t = b; b = c; c = t; }
  if (a > b) { float t = a; a = b; b = t; }
  return b;
}

// Read accelerometer through a 3-sample median filter
void readAccel(float &ax, float &ay, float &az) {
  float rx, ry, rz;
  readAccelRaw(rx, ry, rz);
  accelBufX[accelBufIdx] = rx;
  accelBufY[accelBufIdx] = ry;
  accelBufZ[accelBufIdx] = rz;
  accelBufIdx = (accelBufIdx + 1) % ACCEL_MEDIAN_N;
  ax = med3(accelBufX[0], accelBufX[1], accelBufX[2]);
  ay = med3(accelBufY[0], accelBufY[1], accelBufY[2]);
  az = med3(accelBufZ[0], accelBufZ[1], accelBufZ[2]);
}

void readMag(float &mx, float &my, float &mz) {
  Wire.beginTransmission(LSM303_MAG_ADDR);
  Wire.write(0x03);
  Wire.endTransmission(false);
  Wire.requestFrom(LSM303_MAG_ADDR, (uint8_t)6);
  int16_t rawX = (Wire.read() << 8) | Wire.read();
  int16_t rawZ = (Wire.read() << 8) | Wire.read();
  int16_t rawY = (Wire.read() << 8) | Wire.read();
  mx = rawX / 1100.0f;
  my = rawY / 1100.0f;
  mz = rawZ /  980.0f;
}

// =============================================================================
//  CALIBRATION
// =============================================================================
void runCalibration() {
  // ── Intro — allow exit with BTN_LEFT ─────────────────────────────────────
  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(30, 0);  display.print("CALIBRATION");
  display.setCursor(0, 14); display.print("Move device in a");
  display.setCursor(0, 24); display.print("figure-8 pattern");
  display.setCursor(25, 38); display.print("Press to start");
  display.display();

  // Wait for PRESS to start, LEFT to cancel
  while (true) {
    if (btnPressed(BTN_PRESS)) break;
    if (btnPressed(BTN_LEFT))  { state = MAIN_MENU; menuIndex = 0; return; }
  }

  float x_min =  99999, x_max = -99999;
  float y_min =  99999, y_max = -99999;
  float z_min =  99999, z_max = -99999;

  // We define "done" as achieving >= TARGET_SPREAD on all three axes.
  // A good figure-8 in Earth's field typically gives ~0.4-0.8 Gauss spread.
  // We use a lower threshold and cap at 100% so progress feels natural.
  const float TARGET_SPREAD = 0.60f;   // Gauss — tunable
  // Also enforce a minimum sample count so a single twitch can't finish it
  const int   MIN_SAMPLES   = 80;      // ~8 seconds at 100ms per sample
  int samples = 0;

  while (true) {
    float mx, my, mz;
    readMag(mx, my, mz);
    if (mx < x_min) x_min = mx;  if (mx > x_max) x_max = mx;
    if (my < y_min) y_min = my;  if (my > y_max) y_max = my;
    if (mz < z_min) z_min = mz;  if (mz > z_max) z_max = mz;
    samples++;

    // Progress = min coverage across all three axes, capped at 100%
    float px = (x_max - x_min) / TARGET_SPREAD;
    float py = (y_max - y_min) / TARGET_SPREAD;
    float pz = (z_max - z_min) / TARGET_SPREAD;
    float pMin = px < py ? px : py;
          pMin = pMin < pz ? pMin : pz;
    if (pMin > 1.0f) pMin = 1.0f;
    int barW = (int)(pMin * 126);

    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(22, 0); display.print("CALIBRATING");
    display.setCursor(4, 14); display.print("Keep moving in");
    display.setCursor(16, 24); display.print("figure-8...");

    // Progress bar — outline + fill
    display.drawRect(1, 40, 126, 14, WHITE);
    if (barW > 0) display.fillRect(1, 40, barW, 14, WHITE);

    // Percentage inside bar (inverted colour over filled part)
    int pct = (int)(pMin * 100);
    display.setTextColor(pct > 50 ? BLACK : WHITE);
    display.setCursor(52, 44); display.print(pct); display.print("%");
    display.setTextColor(WHITE);

    display.display();
    delay(100);

    // Done when all axes sufficiently covered AND minimum samples collected
    if (pMin >= 1.0f && samples >= MIN_SAMPLES) break;
  }

  // ── Compute offsets & scales ───────────────────────────────────────────────
  mag_x_offset = (x_max + x_min) / 2.0f;
  mag_y_offset = (y_max + y_min) / 2.0f;
  mag_z_offset = (z_max + z_min) / 2.0f;

  float x_range   = (x_max - x_min) / 2.0f;
  float y_range   = (y_max - y_min) / 2.0f;
  float z_range   = (z_max - z_min) / 2.0f;
  float avg_range = (x_range + y_range + z_range) / 3.0f;
  mag_x_scale = (x_range > 0.001f) ? avg_range / x_range : 1.0f;
  mag_y_scale = (y_range > 0.001f) ? avg_range / y_range : 1.0f;
  mag_z_scale = (z_range > 0.001f) ? avg_range / z_range : 1.0f;

  // ── Done ──────────────────────────────────────────────────────────────────
  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(20, 10); display.print("CALIBRATION");
  display.setCursor(28, 24); display.print("COMPLETE!");
  display.setCursor(10, 42); display.print("Your compass is");
  display.setCursor(16, 52); display.print("ready to use.");
  display.display();
  delay(2500);
  state = MAIN_MENU;
  menuIndex = 0;
}

// =============================================================================
//  HEADING  — adaptive-alpha circular complementary filter
// =============================================================================
float getHeading() {
  float ax, ay, az, mx, my, mz;
  readAccel(ax, ay, az);
  readMag(mx, my, mz);

  // Hard-iron correction + soft-iron scale
  float cx = (mx - mag_x_offset) * mag_x_scale;
  float cy = (my - mag_y_offset) * mag_y_scale;
  float cz = (mz - mag_z_offset) * mag_z_scale;

  // Normalise accelerometer
  float norm = sqrtf(ax*ax + ay*ay + az*az);
  if (norm < 0.1f) return filteredHeading;   // sensor error guard
  ax /= norm; ay /= norm; az /= norm;

  // Tilt-compensation via full rotation matrix:
  // East vector  E = A x M (normalised)
  // North vector N = E x A
  float Ex = ay*cz - az*cy;
  float Ey = az*cx - ax*cz;
  float Ez = ax*cy - ay*cx;
  float eNorm = sqrtf(Ex*Ex + Ey*Ey + Ez*Ez);
  if (eNorm < 1e-6f) return filteredHeading;
  Ex /= eNorm; Ey /= eNorm; Ez /= eNorm;

  float Nx = Ey*az - Ez*ay;
  float Ny = Ez*ax - Ex*az;   // full N vector (improves accuracy near poles)

  float h = atan2f(-Ex, Nx) * 180.0f / PI;
  (void)Ny;                    // suppress unused-variable warning
  if (h < 0.0f)    h += 360.0f;
  if (h >= 360.0f) h -= 360.0f;

  // Adaptive alpha: slow filter when heading is stable, faster when rotating
  float diff = h - filteredHeading;
  if (diff >  180.0f) diff -= 360.0f;
  if (diff < -180.0f) diff += 360.0f;
  float absDiff = fabsf(diff);

  // Alpha rises from 0.08 (stable) to 0.35 (fast rotation > 30 deg/step)
  float alpha = 0.08f + 0.27f * constrain(absDiff / 30.0f, 0.0f, 1.0f);

  // Circular (unit-vector) blend to avoid 0/360 wrap artefacts
  float hRad = h              * (PI / 180.0f);
  float fRad = filteredHeading * (PI / 180.0f);
  float sinF = (1.0f - alpha) * sinf(fRad) + alpha * sinf(hRad);
  float cosF = (1.0f - alpha) * cosf(fRad) + alpha * cosf(hRad);
  filteredHeading = atan2f(sinF, cosF) * (180.0f / PI);
  if (filteredHeading < 0.0f) filteredHeading += 360.0f;
  return filteredHeading;
}

// =============================================================================
//  TILT  — EMA-smoothed roll & pitch
// =============================================================================
void getTilt(float &roll, float &pitch) {
  float ax, ay, az;
  readAccel(ax, ay, az);
  float norm = sqrtf(ax*ax + ay*ay + az*az);
  if (norm < 0.1f) { roll = smoothRoll; pitch = smoothPitch; return; }
  ax /= norm; ay /= norm; az /= norm;

  float rawRoll  = atan2f(ay, az)                    * (180.0f / PI);
  float rawPitch = atan2f(-ax, sqrtf(ay*ay + az*az)) * (180.0f / PI);

  // EMA alpha 0.2 — smooth but still responsive
  const float a = 0.2f;
  smoothRoll  = (1.0f - a) * smoothRoll  + a * rawRoll;
  smoothPitch = (1.0f - a) * smoothPitch + a * rawPitch;

  roll  = smoothRoll;
  pitch = smoothPitch;
}

