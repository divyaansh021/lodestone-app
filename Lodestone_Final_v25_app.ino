// =============================================================================
// =============================================================================
//  WiFi — scan networks
// =============================================================================
void scanNetworks() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(0, 0); display.print("Scanning WiFi...");
  display.display();

  // Ensure radio is in a clean STA state before scanning.
  // If we're stuck in a failed connection the scan returns 0 otherwise.
  WiFi.disconnect(true);   // disconnect + clear credentials
  WiFi.mode(WIFI_STA);
  delay(100);              // give the radio a moment to settle

  int n = WiFi.scanNetworks(/*async=*/false, /*show_hidden=*/false);

  // n == -1 (WIFI_SCAN_FAILED) or -2 (WIFI_SCAN_RUNNING) means something
  // went wrong — retry once after a longer settle time.
  if (n < 0) {
    display.setCursor(0, 14); display.print("Retrying...");
    display.display();
    WiFi.scanDelete();
    delay(500);
    n = WiFi.scanNetworks(false, false);
  }

  networkCount = 0;
  if (n > 0) {
    for (int i = 0; i < n && networkCount < MAX_NETWORKS; i++) {
      scannedSSIDs[networkCount] = WiFi.SSID(i);
      scannedRSSI[networkCount]  = WiFi.RSSI(i);
      networkCount++;
    }
  }
  WiFi.scanDelete();  // free scan memory

  if (networkCount == 0) {
    display.clearDisplay();
    display.setCursor(0, 0);  display.print("No networks found!");
    display.display();
    delay(2000);
    state = MAIN_MENU; menuIndex = 0;
  }
}

// =============================================================================
//  UDP — broadcast my position
// =============================================================================
// =============================================================================
//  MQTT — callback (incoming messages)
// =============================================================================
void mqttCallback(char* topic, byte* payload, unsigned int length) {
  String t = String(topic);
  String msg = "";
  for (unsigned int i = 0; i < length; i++) msg += (char)payload[i];

  StaticJsonDocument<512> doc;
  if (deserializeJson(doc, msg) != DeserializationError::Ok) return;

  // ── Announce from another device ──────────────────────────────────────────
  if (t == "lodestone/announce") {
    String mac = doc["mac"] | "";
    if (mac == myMacStr || mac == "") return;
    const char* name = doc["name"] | "Unknown";
    // (dedupe by full MAC happens further down)
    bool hw = (String(doc["type"] | "") == "hardware");
    bool isApp = (String(doc["type"] | "") == "app");
    // Track app clients separately
    if (isApp) {
      bool found = false;
      for (int i = 0; i < appClientCount; i++) {
        if (String(appClients[i].mac) == mac) {
          strncpy(appClients[i].name, name, 31);
          appClients[i].lastSeen = millis();
          found = true; break;
        }
      }
      if (!found && appClientCount < 10) {
        strncpy(appClients[appClientCount].name, name, 31);
        strncpy(appClients[appClientCount].mac, mac.c_str(), 19);
        appClients[appClientCount].lastSeen = millis();
        appClientCount++;
      }
    }
    // Update existing by mac string
    bool updated = false;
    for (int i = 0; i < nearbyCount; i++) {
      char storedMac[20];
      snprintf(storedMac, sizeof(storedMac), "%02X:%02X:%02X:%02X:%02X:%02X",
               nearbyDevices[i].mac[0],nearbyDevices[i].mac[1],nearbyDevices[i].mac[2],
               nearbyDevices[i].mac[3],nearbyDevices[i].mac[4],nearbyDevices[i].mac[5]);
      if (mac == String(storedMac)) {
        nearbyDevices[i].lastSeen  = millis();
        nearbyDevices[i].isHardware = hw;
        strncpy(nearbyDevices[i].name, name, 15);
        updated = true; break;
      }
    }
    if (!updated && nearbyCount < MAX_DEVICES) {
      strncpy(nearbyDevices[nearbyCount].name, name, 15);
      nearbyDevices[nearbyCount].lastSeen   = millis();
      nearbyDevices[nearbyCount].lat        = 0;
      nearbyDevices[nearbyCount].lon        = 0;
      nearbyDevices[nearbyCount].heading    = 0;
      nearbyDevices[nearbyCount].isHardware = hw;
      // Parse mac string into bytes
      int m0,m1,m2,m3,m4,m5;
      if (sscanf(mac.c_str(), "%X:%X:%X:%X:%X:%X",&m0,&m1,&m2,&m3,&m4,&m5)==6) {
        nearbyDevices[nearbyCount].mac[0]=m0; nearbyDevices[nearbyCount].mac[1]=m1;
        nearbyDevices[nearbyCount].mac[2]=m2; nearbyDevices[nearbyCount].mac[3]=m3;
        nearbyDevices[nearbyCount].mac[4]=m4; nearbyDevices[nearbyCount].mac[5]=m5;
      }
      nearbyCount++;
    }
  }

  // ── Position update from paired device ────────────────────────────────────
  String pairPrefix = "lodestone/pair/";
  if (t.startsWith(pairPrefix)) {
    String mac = doc["mac"] | "";
    if (mac == myMacStr || mac.length() == 0) return;
    // Only accept from actually-paired devices
    String _pm = mac; _pm.replace(":", "");
    if (!isAlreadyPaired(_pm)) return;
    double lat = doc["lat"] | 0.0;
    double lon = doc["lon"] | 0.0;
    float  hdg = doc["heading"] | 0.0f;
    const char* name = doc["name"] | "Device";
    // Match by MAC bytes
    int mm0,mm1,mm2,mm3,mm4,mm5;
    if (sscanf(mac.c_str(), "%X:%X:%X:%X:%X:%X",&mm0,&mm1,&mm2,&mm3,&mm4,&mm5) != 6) return;
    for (int i = 0; i < nearbyCount; i++) {
      if (nearbyDevices[i].mac[0]==mm0 && nearbyDevices[i].mac[1]==mm1 &&
          nearbyDevices[i].mac[2]==mm2 && nearbyDevices[i].mac[3]==mm3 &&
          nearbyDevices[i].mac[4]==mm4 && nearbyDevices[i].mac[5]==mm5) {
        nearbyDevices[i].lat      = lat;
        nearbyDevices[i].lon      = lon;
        nearbyDevices[i].heading  = hdg;
        nearbyDevices[i].lastSeen = millis();
        strncpy(nearbyDevices[i].name, name, 15);
        return;
      }
    }
  }

  // ── Pair request from app ─────────────────────────────────────────────────
  String reqTopic = "lodestone/request/" + myMacStr;
  reqTopic.replace(":", "");
  if (t == reqTopic) {
    const char* requesterName = doc["name"] | "Unknown";
    String      requesterMac  = doc["mac"] | "";
    if (requesterMac.length() == 0) return;  // ignore empty/spoofed
    // Already paired? Silently ignore repeat requests.
    String _cleanReq = requesterMac; _cleanReq.replace(":", "");
    if (isAlreadyPaired(_cleanReq)) return;
    // Don't interrupt if a pair dialog is already open.
    if (state == PAIR_REQUEST) return;
    strncpy(pendingPairName, requesterName, 15);
    pendingPairName[15] = '␀';
    pendingPairMac = requesterMac;
    state = PAIR_REQUEST;
  }

  // ── Pair accepted by the other Lodestone (we sent the request) ────────────
  String myCleanAcc = myMacStr; myCleanAcc.replace(":", "");
  if (t == "lodestone/accept/" + myCleanAcc) {
    String acceptorMac = doc["mac"] | "";
    const char* acceptorName = doc["name"] | "Device";
    if (acceptorMac.length() == 0) return;
    String cleanAcc = acceptorMac; cleanAcc.replace(":", "");
    if (!isAlreadyPaired(cleanAcc)) {
      addPairedDevice(cleanAcc);  // now THIS device stores the pair too
    }
    // Subscribe to the pair topic so we receive their position updates
    String pairTopicStr = "lodestone/pair/" + myCleanAcc + "_" + cleanAcc;
    mqtt.subscribe(pairTopicStr.c_str());
    pairTopicStr = "lodestone/pair/" + cleanAcc + "_" + myCleanAcc;
    mqtt.subscribe(pairTopicStr.c_str());
    // Show confirmation
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(10, 20); display.print("Paired with:");
    display.setCursor(10, 34); display.print(acceptorName);
    display.display();
    delay(1500);
    return;
  }

  // ── Unpair request from app ──────────────────────────────────────────────
  String myCleanUp = myMacStr; myCleanUp.replace(":", "");
  if (t == "lodestone/unpair/" + myCleanUp) {
    const char* requesterName = doc["name"] | "App";
    // Remove this MAC from pairedMacs
    String requesterMac = doc["mac"] | "";
    requesterMac.replace(":", "");
    removePairedDevice(requesterMac);
    // Unsubscribe from pair topic
    String pairTopicStr = "lodestone/pair/" + myCleanUp + "_" + requesterMac;
    mqtt.unsubscribe(pairTopicStr.c_str());
    pairTopicStr = "lodestone/pair/" + requesterMac + "_" + myCleanUp;
    mqtt.unsubscribe(pairTopicStr.c_str());
    // Show brief notification
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(0, 20); display.print("Unpaired by:");
    display.setCursor(0, 34); display.print(requesterName);
    display.display();
    delay(1500);
    return;
  }

  // ── Location request from app ────────────────────────────────────────────
  String myCleanLoc = myMacStr; myCleanLoc.replace(":", "");
  if (t == "lodestone/loc/request/" + myCleanLoc) {
    publishLocations();
    return;
  }

  // ── Incoming message ─────────────────────────────────────────────────────
  if (t.startsWith("lodestone/msg/")) {
    const char* sender = doc["from"] | "Unknown";
    const char* msgTxt = doc["msg"]  | "";
    // Paired-only: silently drop messages from unpaired senders.
    String _sm = doc["mac"] | "";
    _sm.replace(":", "");
    if (_sm.length() == 0 || !isAlreadyPaired(_sm)) return;
    // Shift inbox up, add new message
    if (inboxCount < 5) inboxCount++;
    for (int i = inboxCount-1; i > 0; i--)
      strncpy(inboxMsgs[i], inboxMsgs[i-1], 63);
    char combined[64];
    snprintf(combined, sizeof(combined), "%s: %s", sender, msgTxt);
    strncpy(inboxMsgs[0], combined, 63);
    // Flash notification on screen briefly if not already in MSG_INBOX
    if (state != MSG_INBOX && state != MSG_COMPOSE) {
      display.clearDisplay();
      display.setTextSize(1);
      display.setCursor(0, 0);  display.print("MSG from ");
      display.print(sender);
      display.setCursor(0, 16); display.print(msgTxt);
      display.display();
      delay(2000);
    }
  }

  // ── Location sync from app ────────────────────────────────────────────────
  if (t == "lodestone/locations") {
    String mac = doc["mac"] | "";
    JsonArray locs = doc["locations"].as<JsonArray>();
    if (locs.isNull()) return;
    locationCount = 0;
    for (JsonObject loc : locs) {
      if (locationCount >= 10) break;
      const char* n = loc["name"] | "";
      double la = loc["lat"] | 0.0;
      double lo = loc["lon"] | 0.0;
      strncpy(locations[locationCount].name, n, 15);
      locations[locationCount].lat = la;
      locations[locationCount].lon = lo;
      locationCount++;
    }
    saveLocations();
    display.clearDisplay();
    display.setTextSize(1);
    display.setCursor(10, 20); display.print("Locations synced");
    display.setCursor(10, 34); display.print("from app!");
    display.display();
    delay(1200);
  }
}

// =============================================================================
//  MQTT — connect / maintain
// =============================================================================
void connectMQTT() {
  if (!wifiConnected) return;
  wifiSecure.setInsecure();   // skip cert verify (fine for HiveMQ Cloud)
  mqtt.setServer(MQTT_HOST, MQTT_PORT);
  mqtt.setCallback(mqttCallback);
  mqtt.setBufferSize(512);
  mqtt.setKeepAlive(30);

  String clientId = "lodestone_" + myMacStr;
  clientId.replace(":", "");

  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(0, 0);  display.print("Connecting MQTT...");
  display.display();

  if (mqtt.connect(clientId.c_str(), MQTT_USER, MQTT_PASS)) {
    mqttConnected = true;
    // Subscribe to announce, pair requests, location sync
    mqtt.subscribe("lodestone/announce");
    mqtt.subscribe("lodestone/locations");
    String reqTopic = "lodestone/request/" + myMacStr;
    reqTopic.replace(":", "");
    mqtt.subscribe(reqTopic.c_str());
    String myClean = myMacStr; myClean.replace(":", "");
    String msgTopic = "lodestone/msg/" + myClean;
    mqtt.subscribe(msgTopic.c_str());
    // (global lodestone/msg/broadcast deliberately not subscribed — paired-only messaging)
    String myCleanUnpair = myMacStr; myCleanUnpair.replace(":", "");
    mqtt.subscribe(("lodestone/unpair/" + myCleanUnpair).c_str());
    String myCleanSub = myMacStr; myCleanSub.replace(":", "");
    mqtt.subscribe(("lodestone/loc/request/" + myCleanSub).c_str());
    // Subscribe to accept notifications so THIS device knows when its pair request was accepted
    String myCleanAcc = myMacStr; myCleanAcc.replace(":", "");
    mqtt.subscribe(("lodestone/accept/" + myCleanAcc).c_str());
    announcePresence();
    resubscribePaired();
    publishLocations();  // send stored locations to app
  }
}


// =============================================================================
//  MQTT — publish stored locations to app
// =============================================================================
void publishLocations() {
  if (!mqtt.connected()) return;
  // Build JSON array using snprintf — avoids quote escaping issues
  String json = "[";
  char locBuf[96];
  for (int i = 0; i < locationCount; i++) {
    if (i > 0) json += ",";
    snprintf(locBuf, sizeof(locBuf),
      "{\"name\":\"%s\",\"lat\":%.6f,\"lon\":%.6f}",
      locations[i].name,
      locations[i].lat,
      locations[i].lon);
    json += locBuf;
  }
  json += "]";
  String myClean = myMacStr; myClean.replace(":", "");
  String topic = "lodestone/loc/response/" + myClean;
  mqtt.publish(topic.c_str(), json.c_str(), true);
}

// =============================================================================
//  MQTT — announce presence
// =============================================================================
void announcePresence() {
  if (!mqtt.connected()) return;
  char annBuf[128];
  snprintf(annBuf, sizeof(annBuf), "{\"name\":\"%s\",\"mac\":\"%s\",\"type\":\"hardware\"}",
           deviceName, myMacStr.c_str());
  mqtt.publish("lodestone/announce", annBuf, true);
}

// =============================================================================
//  MQTT — broadcast GPS position to paired devices
// =============================================================================
void broadcastPosition() {
  if (!mqtt.connected()) return;
  if (!gps.location.isValid()) return;
  if (millis() - lastMqttSend < MQTT_INTERVAL) return;
  lastMqttSend = millis();

  StaticJsonDocument<256> doc;
  doc["name"]    = deviceName;
  doc["mac"]     = myMacStr;
  doc["lat"]     = gps.location.lat();
  doc["lon"]     = gps.location.lng();
  doc["heading"] = filteredHeading;
  doc["speed"]   = gps.speed.isValid() ? gps.speed.kmph() : 0.0;

  char buf[256];
  serializeJson(doc, buf);

  // Publish to a shared topic — app subscribes to lodestone/devices/<mac>
  String topic = "lodestone/devices/" + myMacStr;
  topic.replace(":", "");
  mqtt.publish(topic.c_str(), buf);

  // Also publish to each paired Lodestone's pair topic so they can track us.
  // The other device subscribes to lodestone/pair/<theirMac>_<ourMac>.
  String myClean = myMacStr; myClean.replace(":", "");
  for (int i = 0; i < pairedMacCount; i++) {
    String peerClean = String(pairedMacs[i]);
    String pairTopic = "lodestone/pair/" + peerClean + "_" + myClean;
    mqtt.publish(pairTopic.c_str(), buf);
  }
}

// =============================================================================
//  MQTT — receive positions (now handled in callback — stub kept for compat)
// =============================================================================
void receivePositions() { mqtt.loop(); }

// =============================================================================
//  Prune stale devices
// =============================================================================
void pruneDevices() {
  for (int i = 0; i < nearbyCount; i++) {
    if (millis() - nearbyDevices[i].lastSeen > 30000) {
      for (int j = i; j < nearbyCount - 1; j++)
        nearbyDevices[j] = nearbyDevices[j + 1];
      nearbyCount--;
      i--;
    }
  }
}

