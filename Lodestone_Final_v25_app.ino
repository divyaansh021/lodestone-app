// ─── Sleep / settings helpers ────────────────────────────────────────────────
void resetActivity() {
  lastActivityTime = millis();
  if (displaySleeping) {
    Wire.beginTransmission(SCREEN_ADDRESS);
    Wire.write(0x00); Wire.write(0xAF);  // SH1106G display ON
    Wire.endTransmission();
    displaySleeping = false;
  }
}

void checkSleep() {
  if (sleepTimeoutMin == 0) return;
  if (state != MAIN_MENU) { lastActivityTime = millis(); return; }
  if (!displaySleeping &&
      millis() - lastActivityTime > (unsigned long)sleepTimeoutMin * 60000UL) {
    display.clearDisplay();
    display.display();
    Wire.beginTransmission(SCREEN_ADDRESS);
    Wire.write(0x00); Wire.write(0xAE);  // SH1106G display OFF
    Wire.endTransmission();
    displaySleeping = true;
  }
}

